@startuml
class DictionaryLanguage::Author {
  + email : str
}
class DictionaryLanguage::Dictionary {
  + title : str
}
class DictionaryLanguage::Entry {
  + content : str
  + level : str
}
class DictionaryLanguage::Library {
  + name : str
}
class DictionaryLanguage::Shelf {
  + description : str
}
DictionaryLanguage::Author "1..1" -- "1..1" DictionaryLanguage::Dictionary : author4
DictionaryLanguage::Author "0..9999" --* "1..1" DictionaryLanguage::Library : author8
DictionaryLanguage::Author "1..1" -- "0..9999" DictionaryLanguage::Dictionary : dictionary1
DictionaryLanguage::Dictionary "0..9999" --* "1..1" DictionaryLanguage::Shelf : dictionary10
DictionaryLanguage::Dictionary "1..1" *-- "0..9999" DictionaryLanguage::Entry : entry6
DictionaryLanguage::Author "1..1" -- "1..1" DictionaryLanguage::Library : library0
DictionaryLanguage::Dictionary "1..1" -- "1..1" DictionaryLanguage::Shelf : shelf3
DictionaryLanguage::Library "1..1" *-- "0..9999" DictionaryLanguage::Shelf : shelf7
@enduml