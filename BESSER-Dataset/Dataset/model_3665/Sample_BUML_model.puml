@startuml
class sample::Company {
  + name : str
}
class sample::Department {
  + name : str
}
class sample::Group {
  + name : str
}
class sample::Person {
  + birthdate : date
  + name : str
}
sample::Company "0..1" -- "1..1" sample::Department : company2
sample::Group "1..1" -- "0..1" sample::Department : department4
sample::Department "0..9999" --* "1..1" sample::Company : departments0
sample::Group "0..1" -- "1..1" sample::Person : group6
sample::Department "1..1" *-- "0..9999" sample::Group : groups1
sample::Person "0..9999" --* "1..1" sample::Group : persons3
@enduml