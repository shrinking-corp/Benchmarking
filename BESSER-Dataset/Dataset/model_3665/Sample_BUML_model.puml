@startuml
class sample::Company {
  + name : str
}
class sample::Department {
  + name : str
}
class sample::Group {
  + name : str
}
class sample::Person {
  + birthdate : date
  + name : str
}
sample::Company "0..1" -- "1..1" sample::Department : company2
sample::Department "0..1" -- "1..1" sample::Group : department4
sample::Company "1..1" *-- "0..9999" sample::Department : departments0
sample::Group "0..1" -- "1..1" sample::Person : group6
sample::Department "1..1" *-- "0..9999" sample::Group : groups1
sample::Group "1..1" *-- "0..9999" sample::Person : persons3
@enduml