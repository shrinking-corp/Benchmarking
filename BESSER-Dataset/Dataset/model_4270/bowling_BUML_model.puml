@startuml
enum TournamentType {
  Amateur
  Pro
}
class bowling::Game {
  + frames : int
}
class bowling::League {
  + name : str
}
class bowling::Matchup {
  + date : date
}
class bowling::Player {
  + dateOfBirth : date
  + eMail : str
  + height : float
  + isProfessional : bool
  + name : str
  + street : str
  + streetNumber : int
}
class bowling::Tournament {
  + title : str
  + type : str
}
bowling::Game "0..9999" -- "1..1" bowling::Player : games0
bowling::Game "0..2" --* "1..1" bowling::Matchup : games6
bowling::League "0..1" -- "1..1" bowling::Tournament : league3
bowling::Game "1..1" -- "1..1" bowling::Matchup : matchup8
bowling::Matchup "0..9999" --* "1..1" bowling::Tournament : matchups2
bowling::Game "1..1" -- "0..1" bowling::Player : player9
bowling::League "1..1" *-- "0..9999" bowling::Player : players1
@enduml