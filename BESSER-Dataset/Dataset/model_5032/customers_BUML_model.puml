customers::Address "1..1" --* "1..1" customers::Customer : address1
customers::CreditCard "0..9999" --* "1..1" customers::Customer : creditCard0
customers::Customer "0..9999" --* "1..1" customers::CustomersDB : customers3
customers::CreditCard "1..1" -- "1..1" customers::Customer : holder2
