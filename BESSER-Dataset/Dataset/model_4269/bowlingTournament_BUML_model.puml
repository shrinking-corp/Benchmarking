@startuml
enum TournamentType {
  Amateur
  Pro
}
class bowlingTournament::Game {
  + frames : int
}
class bowlingTournament::League {
  + name : str
}
class bowlingTournament::Matchup {
}
class bowlingTournament::Player {
  + dateOfBirth : date
  + height : float
  + isProfessional : bool
  + name : str
}
class bowlingTournament::Tournament {
  + type : str
}
bowlingTournament::Game "0..2" --* "1..1" bowlingTournament::Matchup : games5
bowlingTournament::League "0..9999" --* "1..1" bowlingTournament::Tournament : league2
bowlingTournament::Game "1..1" -- "0..1" bowlingTournament::Matchup : matchup8
bowlingTournament::Matchup "0..9999" --* "1..1" bowlingTournament::Tournament : matchups1
bowlingTournament::League "1..1" *-- "0..9999" bowlingTournament::Player : player0
bowlingTournament::Game "1..1" *-- "0..1" bowlingTournament::Player : player6
@enduml