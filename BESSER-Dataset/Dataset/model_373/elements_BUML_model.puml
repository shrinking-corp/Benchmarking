@startuml
enum BookCategory {
  Biography
  Mystery
  ScienceFiction
}
class elements::Book {
  + category : str
  + pages : str
  + title : str
}
class elements::Writer {
  + name : str
}
elements::Book "1..1" -- "1..1" elements::Writer : author0
elements::Book "0..9999" -- "1..1" elements::Writer : books1
@enduml