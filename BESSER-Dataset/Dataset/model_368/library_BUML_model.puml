@startuml
class library::Book {
  + pages : int
  + title : str
}
class library::Library {
  + name : str
}
class library::Writer {
  + firstName : str
  + lastName : str
}
library::Library "1..1" *-- "0..9999" library::Book : books1
library::Book "0..9999" -- "1..1" library::Writer : books3
library::Writer "0..9999" --* "1..1" library::Library : writers0
library::Book "1..1" -- "0..9999" library::Writer : writers6
@enduml