@startuml
class hierarchy::Book {
  + Name : str
  + genre : str
}
class hierarchy::Fiction {
  + Name : str
}
class hierarchy::HierLibrary {
  + Name : str
}
class hierarchy::NonFiction {
  + Name : str
}
hierarchy::Fiction "0..1" --* "1..1" hierarchy::HierLibrary : fiction0
