@startuml
class hierarchy::Book {
  + Name : str
  + genre : str
}
class hierarchy::Fiction {
  + Name : str
}
class hierarchy::HierLibrary {
  + Name : str
}
class hierarchy::NonFiction {
  + Name : str
}
hierarchy::HierLibrary "1..1" *-- "0..1" hierarchy::Fiction : fiction0
hierarchy::Fiction "1..1" *-- "0..9999" hierarchy::Book : members3
hierarchy::Book "0..9999" --* "1..1" hierarchy::NonFiction : members5
hierarchy::NonFiction "0..1" --* "1..1" hierarchy::HierLibrary : nonfiction1
@enduml