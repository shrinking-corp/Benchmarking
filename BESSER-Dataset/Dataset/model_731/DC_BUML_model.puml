}
class dc::Bounds {
  + height : str
  + width : str
  + x : str
  + y : str
  + nonNegativeHeight(context : any, diagnostics : any) : bool
  + nonNegativeWidth(context : any, diagnostics : any) : bool
}
class dc::Dimension {
  + height : str
  + width : str
  + nonNegativeHeight(context : any, diagnostics : any) : bool
  + nonNegativeWidth(context : any, diagnostics : any) : bool
}
class dc::Point {
  + x : str
  + y : str
}
@enduml