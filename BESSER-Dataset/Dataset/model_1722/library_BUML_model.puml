@startuml
class library::Book {
  + Name : str
  + genre : str
}
class library::Fiction {
  + Name : str
}
class library::Library {
  + Name : str
}
class library::NonFiction {
  + Name : str
}
library::Book "0..9999" --* "1..1" library::Library : books1
library::Fiction "0..1" --* "1..1" library::Library : fiction6
library::Book "0..9999" -- "1..1" library::NonFiction : members0
library::Book "0..9999" -- "1..1" library::Fiction : members8
library::Library "1..1" *-- "0..1" library::NonFiction : nonfiction3
@enduml