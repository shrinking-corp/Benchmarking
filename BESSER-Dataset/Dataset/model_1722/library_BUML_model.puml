@startuml
class library::Book {
  + Name : str
  + genre : str
}
class library::Fiction {
  + Name : str
}
class library::Library {
  + Name : str
}
class library::NonFiction {
  + Name : str
}
library::Library "1..1" *-- "0..9999" library::Book : books1
library::Fiction "0..1" --* "1..1" library::Library : fiction6
library::Book "0..9999" -- "1..1" library::NonFiction : members0
library::Fiction "1..1" -- "0..9999" library::Book : members8
library::NonFiction "0..1" --* "1..1" library::Library : nonfiction3
@enduml