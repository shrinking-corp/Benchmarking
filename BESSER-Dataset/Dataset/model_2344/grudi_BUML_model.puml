@startuml
enum Gender {
  female
  male
  unknown
}
enum TeamPersonKind {
  captain
  member
}
class grudi::Person {
  + address : str
  + email : str
  + gender : str
  + id : str
  + name : str
  + password : str
  + phoneNumber : str
  + username : str
  + versionNumber : str
}
class grudi::PersonInfo {
  + gender : str
  + id : str
  + name : str
  + phoneNumber : str
  + userName : str
}
class grudi::Team {
  + id : str
  + name : str
  + versionNumber : str
}
class grudi::TeamLine {
  + id : str
  + kind : str
  + versionNumber : str
}
grudi::Team "1..1" -- "0..9999" grudi::TeamLine : lines0
grudi::PersonInfo "0..1" -- "1..1" grudi::TeamLine : person2
grudi::Team "0..1" -- "1..1" grudi::TeamLine : team1
@enduml