  DARK_GRAY
  GRAY
  GREEN
  LIGHT_GRAY
  MAGENTA
  ORANGE
  PINK
  RED
  WHITE
  YELLOW
}
enum CompareOperator {
  EQ
  G
  GEQ
  L
  LEQ
  NEQ
}
enum Directions {
  E
  N
  NE
  NW
  S
  SE
  SW
  W
}
class SensorType {
}
enum TouchSensorSides {
  ANY
  BOTH
  LEFT
  RIGHT
}
class dsl::ColorSensor {
  + distinct : bool
}
class dsl::ColorValue {
  + color : str
}
class dsl::Ignorables {
