}
enum timeUnit {
  MILISECONDS
  SECONDS
}
SensorType <|-- dsl::ColorSensor
SensorType <|-- dsl::TouchSensor
SensorType <|-- dsl::UltrasonicSensor
dsl::Ignorables "0..1" --* "1..1" dsl::Task : ignoreBehavior3
dsl::ColorSensor "1..1" *-- "0..1" dsl::ColorValue : key7
dsl::ColorSensor "1..1" *-- "0..9999" dsl::ColorValue : keys8
dsl::SensorType "0..1" --* "1..1" dsl::Task : sensor1
dsl::Mission "1..1" *-- "0..9999" dsl::Task : tasks0
dsl::Task "1..1" *-- "0..1" dsl::timeUnitValue : timeunit5
@enduml