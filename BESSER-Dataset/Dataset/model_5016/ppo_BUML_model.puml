@startuml
class ppo::Item {
  + comment : str
  + partNum : str
  + productName : str
  + quantity : int
  + shipDate : date
  + uSPrice : int
}
class ppo::PurchaseOrder {
  + comment : str
  + orderDate : date
}
class ppo::USAddress {
  + city : str
  + country : str
  + name : str
  + state : str
  + street : str
  + zip : int
}
ppo::USAddress "1..1" --* "1..1" ppo::PurchaseOrder : billTo1
ppo::Item "0..9999" --* "1..1" ppo::PurchaseOrder : items0
ppo::PurchaseOrder "1..1" *-- "1..1" ppo::USAddress : shipTo3
@enduml