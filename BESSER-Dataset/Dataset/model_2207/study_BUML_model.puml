@startuml
enum Season {
  FALL
  SPRING
}
class study::Course {
  + code : str
  + credits : float
  + level : int
  + name : str
}
class study::Department {
  + name : str
}
class study::Programme {
  + code : str
  + duration : int
  + name : str
}
class study::Semester {
  + Season : str
  + year : int
}
class study::SemesterCourse {
  + mandatory : bool
}
class study::Specialization {
  + name : str
}
