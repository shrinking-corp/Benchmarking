@startuml
enum AnnotationColor {
  Blue
  Green
  Purple
  Red
  Underline
  Yellow
}
class Bookmark {
}
class library::Book {
  + author : str
  + bookURL : str
  + bookURN : str
  + collection : str
  + lastHref : str
  + lastLocation : str
  + lastOpened : str
  + title : str
}
class library::Bookmark {
  + href : str
  + id : str
  + location : str
  + page : int
  + text : str
  + timestamp : date
}
class library::Library {
  + version : str
}
class library::Metadata {
  + key : str
  + value : str
}
class library::TextAnnotation {
  + color : str
  + comment : str
}
Bookmark <|-- library::TextAnnotation
library::Book "1..1" *-- "0..9999" library::Bookmark : bookmarks1
library::Book "0..9999" --* "1..1" library::Library : books0
library::Book "1..1" *-- "0..9999" library::Metadata : metadata3
@enduml