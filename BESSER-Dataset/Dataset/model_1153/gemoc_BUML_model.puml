@startuml
class gemoc::FSM {
  + name : str
  + print() : void
}
class gemoc::State {
  + name : str
}
class gemoc::Transition {
  + name : str
  + trigger : str
}
gemoc::Transition "0..1" -- "1..1" gemoc::State : incoming3
gemoc::State "1..1" -- "0..1" gemoc::Transition : outcoming4
gemoc::State "0..1" -- "1..1" gemoc::Transition : src7
gemoc::FSM "1..1" *-- "0..9999" gemoc::State : state0
gemoc::State "0..1" -- "1..1" gemoc::Transition : state6
gemoc::Transition "0..9999" --* "1..1" gemoc::FSM : transition1
