@startuml
class pdb1::Database {
  + name : str
}
class pdb1::Person {
  + birthday : str
  + firstName : str
  + id : str
  + incrementalID : str
  + lastName : str
  + placeOfBirth : str
}
pdb1::Database "0..1" -- "1..1" pdb1::Person : database1
pdb1::Database "1..1" *-- "0..9999" pdb1::Person : persons0
@enduml