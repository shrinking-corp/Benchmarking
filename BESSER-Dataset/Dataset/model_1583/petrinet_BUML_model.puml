@startuml
class petrinet::Net {
  + name : str
}
class petrinet::Place {
  + initialTokens : int
  + name : str
}
class petrinet::Transition {
  + name : str
}
petrinet::Place "1..9999" -- "1..1" petrinet::Transition : input3
petrinet::Transition "1..1" -- "1..9999" petrinet::Place : output6
petrinet::Place "0..9999" --* "1..1" petrinet::Net : places0
petrinet::Transition "0..9999" --* "1..1" petrinet::Net : transitions1
@enduml