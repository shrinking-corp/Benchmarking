@startuml
class petrinet::Net {
  + name : str
}
class petrinet::Place {
  + initialTokens : int
  + name : str
}
class petrinet::Transition {
  + name : str
}
petrinet::Place "1..9999" -- "1..1" petrinet::Transition : input3
petrinet::Place "1..9999" -- "1..1" petrinet::Transition : output6
petrinet::Net "1..1" *-- "0..9999" petrinet::Place : places0
petrinet::Net "1..1" *-- "0..9999" petrinet::Transition : transitions1
@enduml