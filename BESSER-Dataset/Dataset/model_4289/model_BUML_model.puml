@startuml
class Ball {
}
enum BallType {
  dot_ball
  four_runs
  one_run
  six_runs
  three_runs
  two_runs
}
enum ExtraType {
  Bye
  LegBye
  NoBall
  Wide
}
enum HowOut {
  Bowled
  Caught
  Lbw
  Run_Out
  Stumped
}
class model::Ball {
  + runValue : int
  + runs : str
  + switchEnds : str
}
class model::ExtraBall {
