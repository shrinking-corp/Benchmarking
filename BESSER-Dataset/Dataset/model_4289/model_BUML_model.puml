  + isValidBall : str
}
class model::Game {
  + date : date
  + venue : str
}
class model::Innings {
  + Summary : str
  + noOvers : int
  + overCount : str
  + total : int
  + wicketsDown : int
  + bowlBall() : void
  + newOver(bowler : any) : str
}
class model::Over {
  + BALLS_IN_OVER : int
  + isComplete : bool
  + runs : int
  + validBalls : int
}
class model::Player {
  + howOut : str
  + name : str
  + noBallsFaced : int
  + noOversBowled : str
  + runsScored : int
}
class model::Team {
  + name : str
}
class model::WicketBall {
  + howOut : str
}
