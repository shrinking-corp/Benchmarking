@startuml
class attackimpact::EObject {
}
class attackimpact::Model {
  + description : str
  + name : str
}
class attackimpact::Node {
  + description : str
  + domains : str
  + name : str
  + tags : str
}
class attackimpact::Propagation {
  + severity : int
  + tags : str
  + type : str
}
class attackimpact::Vulnerability {
  + description : str
  + name : str
  + severity : int
  + tags : str
  + type : str
}
enum propagationType {
  bus
  data
  dataFlow
  local
  memory
  processor
}
enum vulnerabilityType {
  Authentication
  Concurrency
  Exposure
  Isolation
  ResourceAllocation
  Timing
}
attackimpact::Node "1..9999" -- "1..1" attackimpact::Propagation : destinations8
attackimpact::Model "1..1" *-- "0..9999" attackimpact::Node : nodes11
attackimpact::Node "1..1" *-- "0..9999" attackimpact::Propagation : propagations1
attackimpact::Propagation "0..9999" --* "1..1" attackimpact::Vulnerability : propagations5
attackimpact::EObject "0..1" -- "1..1" attackimpact::Node : relatedObject3
attackimpact::Node "1..1" *-- "0..9999" attackimpact::Vulnerability : vulnerabilities0
@enduml