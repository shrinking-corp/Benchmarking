@startuml
enum BookCategory {
  Biography
  Mystery
  ScienceFiction
}
class cascadenotall::Book {
  + category : str
  + pages : str
  + title : str
}
class cascadenotall::Library {
  + name : str
}
class cascadenotall::Writer {
  + name : str
}
cascadenotall::Book "1..1" -- "1..1" cascadenotall::Writer : author0
cascadenotall::Book "0..9999" --* "1..1" cascadenotall::Library : books2
cascadenotall::Book "0..9999" -- "1..1" cascadenotall::Writer : books4
cascadenotall::Library "1..1" *-- "0..9999" cascadenotall::Writer : writers1
@enduml