@startuml
class demo::model::Address {
  + city : str
  + country : str
  + state : str
  + street : str
  + zipcode : int
}
class demo::model::Company {
  + name : str
}
class demo::model::Employee {
  + birthday : date
  + email : str
  + firstname : str
  + lastname : str
  + phone : str
  + position : str
}
demo::model::Address "0..1" --* "1..1" demo::model::Employee : address2
demo::model::Company "0..1" -- "1..1" demo::model::Employee : company1
demo::model::Employee "0..9999" --* "1..1" demo::model::Company : employees0
@enduml