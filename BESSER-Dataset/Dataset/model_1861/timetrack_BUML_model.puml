@startuml
class timetrack::Library {
}
class timetrack::Project {
  + name : str
  + number : str
}
class timetrack::TimeEntry {
  + day : date
  + duration : date
  + factured : bool
  + from : date
  + notes : str
  + sync_date : date
  + till : date
}
class timetrack::User {
  + name : str
  + password : str
  + sap_name : str
  + sap_password : str
}
timetrack::User "0..9999" --* "1..1" timetrack::Library : listBook3
timetrack::Project "0..9999" --* "1..1" timetrack::Library : listProject8
timetrack::Library "1..1" *-- "0..9999" timetrack::TimeEntry : listTimeEntry5
timetrack::Project "1..1" -- "1..1" timetrack::TimeEntry : project1
timetrack::User "1..1" -- "1..1" timetrack::TimeEntry : user0
@enduml