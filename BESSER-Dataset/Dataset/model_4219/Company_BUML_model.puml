@startuml
class CompanyModel::Company {
  + name : str
}
class CompanyModel::Department {
  + number : int
}
class CompanyModel::Employee {
  + isManager : bool
  + name : str
}
class CompanyModel::Product {
  + name : str
  + productID : int
}
CompanyModel::Company "1..1" *-- "0..9999" CompanyModel::Department : departments0
CompanyModel::Department "1..1" *-- "1..9999" CompanyModel::Employee : employees1
CompanyModel::Department "1..1" *-- "1..9999" CompanyModel::Product : products3
@enduml