@startuml
class CompanyModel::Company {
  + name : str
}
class CompanyModel::Department {
  + number : int
}
class CompanyModel::Employee {
  + isManager : bool
  + name : str
}
class CompanyModel::Product {
  + name : str
  + productID : int
}
CompanyModel::Company "1..1" *-- "0..9999" CompanyModel::Department : departments0
CompanyModel::Employee "1..9999" --* "1..1" CompanyModel::Department : employees1
CompanyModel::Product "1..9999" --* "1..1" CompanyModel::Department : products3
@enduml