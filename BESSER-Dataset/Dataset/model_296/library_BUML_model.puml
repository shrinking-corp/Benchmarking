@startuml
enum BookCategory {
  Biography
  Mystery
  ScienceFiction
}
class library::Book {
  + category : str
  + pages : int
  + title : str
}
class library::Library {
  + name : str
}
class library::Opinion {
  + context : str
  + text : str
}
class library::Review {
  + positive : bool
  + title : str
}
class library::Writer {
  + name : str
}
library::Book "1..1" -- "1..1" library::Writer : author5
library::Opinion "1..1" -- "1..1" library::Book : book11
library::Book "1..1" -- "1..1" library::Review : book7
library::Book "0..9999" --* "1..1" library::Library : books1
library::Book "0..9999" -- "1..1" library::Writer : books3
library::Opinion "0..9999" --* "1..1" library::Writer : opinions4
library::Book "1..1" *-- "0..9999" library::Review : reviews6
library::Writer "1..1" -- "1..1" library::Opinion : writer9
library::Writer "0..9999" --* "1..1" library::Library : writers0
@enduml