@startuml
class shop::Customer {
  + address : str
  + comments : str
  + familyName : str
  + hotel : str
  + surname : str
  + telephoneNr : str
}
class shop::Order {
  + comments : str
  + number : str
}
class shop::PriceCategory {
  + name : str
  + prices : float
}
class shop::Product {
  + description : str
  + name : str
  + number : str
}
class shop::ProductCategory {
  + name : str
}
class shop::Transaction {
  + endDate : date
  + number : str
