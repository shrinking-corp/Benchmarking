}
Family <|-- family::WealthyFamily
family::Family "1..1" *-- "0..1" family::Address : address1
family::Person "1..9999" --* "1..1" family::Family : members0
family::Person "1..1" *-- "0..9999" family::Car : ownedCars3
@enduml