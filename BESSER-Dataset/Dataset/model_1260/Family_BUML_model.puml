@startuml
class Family {
}
enum Sexe {
  FEMALE
  MALE
}
class family::Address {
  + street : str
}
class family::Car {
  + numberOfSeats : str
}
class family::Family {
  + favoriteHolidayDestinations : str
  + hasASwimmingPool : bool
  + numberOfPets : int
  + surname : str
}
class family::Person {
  + firstName : str
  + sexe : str
}
