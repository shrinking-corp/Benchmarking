@startuml
enum TournamentType {
  Amateur
  Pro
}
class bowling::Alley {
  + name : str
}
class bowling::Game {
  + frames : int
}
class bowling::Lane {
  + number : int
}
class bowling::League {
  + name : str
}
class bowling::Matchup {
  + name : str
}
class bowling::Player {
  + dateOfBirth : date
  + height : float
  + isProfessional : bool
  + name : str
}
class bowling::Tournament {
  + name : str
  + type : str
}
bowling::Game "2..2" --* "1..1" bowling::Matchup : games2
bowling::Lane "0..9999" -- "1..1" bowling::Alley : lanes12
bowling::League "0..9999" -- "1..1" bowling::Alley : leagues7
bowling::Tournament "1..1" *-- "0..9999" bowling::Matchup : matchups1
bowling::Player "0..1" -- "1..1" bowling::Game : player4
bowling::Player "0..9999" --* "1..1" bowling::League : players0
bowling::Tournament "0..9999" -- "1..1" bowling::Alley : tournaments9
@enduml