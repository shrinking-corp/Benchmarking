@startuml
enum TournamentType {
  Amateur
  Pro
}
class bowling::Alley {
  + name : str
}
class bowling::Game {
  + frames : int
}
class bowling::Lane {
  + number : int
}
class bowling::League {
  + name : str
}
class bowling::Matchup {
  + name : str
}
class bowling::Player {
  + dateOfBirth : date
  + height : float
  + isProfessional : bool
  + name : str
}
class bowling::Tournament {
  + name : str
  + type : str
}
