@startuml
enum StreetType {
  Road
  Street
}
class rental::Address {
  + city : str
  + number : int
  + streetName : str
  + streetType : str
  + zipCode : str
}
class rental::Customer {
  + firstName : str
  + lastName : str
  + getDisplayName() : str
}
class rental::License {
  + number : int
  + validityDate : date
}
class rental::Rental {
  + endDate : date
  + startDate : date
  + end() : int
  + nbDaysBooked() : int
  + nbDaysRented() : int
  + start() : int
}
class rental::RentalAgency {
  + name : str
  + addCustomer(customer : any) : void
  + addObject(object : any) : void
  + book(customer : any, from : any, rentedObject : any, to : any) : str
}
class rental::RentalObject {
  + ID : str
  + name : str
  + picture : str
  + isAvailable() : bool
  + rent(customer : any) : str
}
