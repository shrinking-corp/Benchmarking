@startuml
enum BookCategory {
  Biography
  Mystery
  ScienceFiction
}
class cascadenotall::Book {
  + category : str
  + pages : str
  + title : str
}
class cascadenotall::Library {
  + name : str
}
class cascadenotall::Writer {
  + name : str
}
cascadenotall::Writer "1..1" -- "1..1" cascadenotall::Book : author0
cascadenotall::Book "0..9999" --* "1..1" cascadenotall::Library : books2
cascadenotall::Writer "1..1" -- "0..9999" cascadenotall::Book : books4
cascadenotall::Writer "0..9999" --* "1..1" cascadenotall::Library : writers1
@enduml