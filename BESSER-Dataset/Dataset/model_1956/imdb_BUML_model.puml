@startuml
enum Genre {
  Adventure
  SciFi
}
enum StaffListType {
  characters
  titles
}
class imdb::Movie {
  + age : int
  + criticReviews : int
  + genres : str
  + metaScore : int
  + metacriticReviews : int
  + poster : str
  + rating : float
  + releaseDate : date
  + runtime : int
  + synopsis : str
  + title : str
  + userRatings : int
  + userReviews : int
}
class imdb::Person {
  + name : str
}
class imdb::StaffList {
  + coverPhoto : str
  + createdDate : date
  + elementType : str
  + elements : str
  + name : str
}
class imdb::User {
  + username : str
  + watchlist : str
}
class imdb::db {
  + bestOf2014 : str
  + sam() : str
}
