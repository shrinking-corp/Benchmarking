  + hasCorrectStreetNumber(context : any, diagnosticianChain : any) : bool
  + hasDateOfBirth(context : any, diagnosticianChain : any) : bool
  + hasGame(context : any, diagnosticianChain : any) : bool
  + hasHeight(context : any, diagnosticianChain : any) : bool
  + hasIsAvailable(context : any, diagnosticianChain : any) : bool
  + hasName(context : any, diagnosticianChain : any) : bool
  + hasNotes(context : any, diagnosticianChain : any) : bool
  + hasStreet(context : any, diagnosticianChain : any) : bool
