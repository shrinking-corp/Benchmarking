@startuml
class graph::Edge {
  + critical : bool
  + update(criticalEdge_p : any, sourceVertex_p : any, targetVertex_p : any) : void
}
class graph::Graph {
  + description : str
  + name : str
  + addAdjacent(critical_p : any, edgeContent_p : any, source_p : any, target_p : any) : void
  + addEdge(edge_p : any) : void
  + addNamedAdjacent(edgeContent : any, edgeName : any, source : any, target : any) : void
  + addVertex(vertex_p : any) : void
}
abstract class graph::GraphElement {
  + name : str
}
class graph::Vertex {
  + hotSpot : bool
  + getEdgeTo(vertex_p : any) : void
  + getIncomingEdgeFrom(vertex_p : any) : void
  + getOutgoingEdgeTo(vertex_p : any) : void
  + hasForAdjacent(vertex_p : any) : bool
  + hasForIncomingAdjacent(vertex_p : any) : bool
  + hasForOutgoingAdjacent(vertex_p : any) : bool
}
@enduml