@startuml
enum Rating {
  BAD
  GOOD
  MEDIUM
  NO_RATING
}
class library::Author {
  + name : str
}
class library::Book {
  + name : str
  + rating : str
}
class library::Library {
  + name : str
}
library::Author "0..1" -- "1..1" library::Book : author3
library::Author "0..9999" --* "1..1" library::Library : authors0
library::Book "0..9999" --* "1..1" library::Library : books1
@enduml