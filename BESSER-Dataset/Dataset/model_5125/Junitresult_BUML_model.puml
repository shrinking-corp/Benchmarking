@startuml
class AbstractAggregatedTest {
}
class JunitResult {
}
class NegativeResult {
}
abstract class junitresult::AbstractAggregatedTest {
  + errors : int
  + failures : int
  + name : str
  + tests : int
}
class junitresult::Error {
}
class junitresult::Failure {
}
abstract class junitresult::JunitResult {
}
abstract class junitresult::NegativeResult {
  + message : str
  + type : str
  + value : str
}
class junitresult::Property {
  + name : str
  + value : str
}
class junitresult::Skipped {
}
class junitresult::Testcase {
  + assertions : str
  + classname : str
  + name : str
  + status : str
  + system_err : str
  + system_out : str
  + time : float
}
class junitresult::Testrun {
  + ignored : int
  + project : str
  + started : int
}
class junitresult::Testsuite {
  + disabled : int
  + hostname : str
  + id : int
  + package : str
  + skipped : int
  + system_err : str
  + system_out : str
  + time : float
  + timestamp : date
}
class junitresult::Testsuites {
  + disabled : int
  + time : float
}
AbstractAggregatedTest <|-- junitresult::Testrun
AbstractAggregatedTest <|-- junitresult::Testsuite
AbstractAggregatedTest <|-- junitresult::Testsuites
JunitResult <|-- junitresult::AbstractAggregatedTest
