@startuml
enum Gender {
  female
  male
}
class company::Company {
  + name : str
  + numberOfManager : int
}
class company::Person {
  + age : int
  + gender : str
  + isUnemployed : bool
  + lastname : str
  + name : str
  + salary : int
}
company::Company "1..1" *-- "0..9999" company::Person : manager1
company::Company "0..1" -- "1..1" company::Person : managerCompanies0
@enduml