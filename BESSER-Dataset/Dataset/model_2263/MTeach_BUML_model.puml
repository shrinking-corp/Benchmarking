@startuml
class mteach::Course {
  + coefficient : float
  + name : str
  + time : int
}
class mteach::Professor {
  + firstName : str
  + lastName : str
}
class mteach::Topic {
  + title : str
}
mteach::Course "0..1" -- "1..1" mteach::Topic : course3
mteach::Course "1..1" -- "0..1" mteach::Professor : professor2
mteach::Course "0..9999" -- "1..1" mteach::Professor : teachedCourses0
mteach::Course "1..1" -- "1..9999" mteach::Topic : topics1
@enduml