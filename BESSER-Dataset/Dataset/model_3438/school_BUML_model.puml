@startuml
class school::Classroom {
  + capacity : int
  + name : str
  + rank : int
  + teacher : str
  + validate(context : any, diagnostic : any) : bool
}
class school::School {
  + city : str
  + director : str
  + name : str
  + zipCode : str
}
class school::Student {
  + age : int
  + name : str
  + nickname : str
  + validate(context : any, diagnostic : any) : bool
}
school::Classroom "0..9999" --* "1..1" school::School : classrooms1
school::Student "0..9999" -- "1..1" school::Student : friends4
school::Classroom "1..1" *-- "0..9999" school::Student : students0
@enduml