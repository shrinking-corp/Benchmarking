@startuml
class Book::Book {
  + title : str
}
class Book::Chapter {
  + author : str
  + nbPages : int
  + title : str
}
class Book::Library {
}
class Book::Summary {
  + content : str
  + nbWords : int
}
Book::Book "0..9999" --* "1..1" Book::Library : books3
Book::Book "1..1" *-- "0..9999" Book::Chapter : chapters0
Book::Chapter "1..1" *-- "0..1" Book::Summary : digest1
@enduml