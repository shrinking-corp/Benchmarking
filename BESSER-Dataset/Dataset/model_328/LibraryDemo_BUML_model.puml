@startuml
enum Category {
  ALL
  FICTION
  POETRY
  SCIENCE
}
class Library::Book {
  + blurb : str
  + category : str
  + pages : int
  + title : str
}
class Library::Library {
  + id : int
  + name : str
}
class Library::Writer {
  + id : int
  + name : str
}
Library::Book "0..9999" --* "1..1" Library::Library : books3
Library::Book "0..9999" -- "1..1" Library::Writer : books7
Library::Book "1..1" -- "1..1" Library::Library : library1
Library::Library "1..1" -- "1..1" Library::Writer : library9
Library::Book "1..1" -- "1..1" Library::Writer : writer0
Library::Library "1..1" *-- "0..9999" Library::Writer : writers4
@enduml