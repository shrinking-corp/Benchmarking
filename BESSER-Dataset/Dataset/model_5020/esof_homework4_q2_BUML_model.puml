@startuml
class esof::homework4::q2::Item {
  + USPrice : int
  + comment : str
  + partNum : str
  + productName : str
  + quantity : int
  + shipDate : str
}
class esof::homework4::q2::PurchaseOrder {
  + comment : str
  + orderDate : str
}
class esof::homework4::q2::USAddress {
  + city : str
  + country : str
  + name : str
  + state : str
  + street : str
  + zip : int
}
esof::homework4::q2::PurchaseOrder "1..1" *-- "1..1" esof::homework4::q2::USAddress : billTo3
esof::homework4::q2::Item "0..9999" --* "1..1" esof::homework4::q2::PurchaseOrder : items0
esof::homework4::q2::PurchaseOrder "1..1" *-- "1..1" esof::homework4::q2::USAddress : shipTo1
@enduml