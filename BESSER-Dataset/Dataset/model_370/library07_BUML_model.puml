@startuml
class library::Author {
  + name : str
}
class library::Book {
  + title : str
}
class library::Employee {
  + name : str
}
class library::Library {
  + name : str
}
class library::Shelf {
  + name : str
}
library::Author "1..1" -- "1..1" library::Book : author1
library::Author "0..9999" --* "1..1" library::Library : authors5
library::Author "1..1" -- "0..9999" library::Book : books0
library::Book "0..9999" --* "1..1" library::Shelf : books10
library::Employee "0..9999" --* "1..1" library::Library : employees7
library::Employee "1..1" -- "0..9999" library::Shelf : shelves2
library::Library "1..1" *-- "0..9999" library::Shelf : shelves3
@enduml