@startuml
enum TournamentType {
  Amateur
  Pro
}
class bowling::Alley {
  + name : str
}
class bowling::Game {
  + frames : int
}
class bowling::Lane {
  + number : int
}
class bowling::League {
  + name : str
}
class bowling::Matchup {
  + name : str
}
class bowling::Player {
  + dateOfBirth : date
  + height : float
  + isProfessional : bool
  + name : str
}
class bowling::Tournament {
  + name : str
  + type : str
}
bowling::Game "2..2" --* "1..1" bowling::Matchup : games2
bowling::Lane "0..9999" -- "1..1" bowling::Alley : lanes11
bowling::League "0..9999" -- "1..1" bowling::Alley : leagues6
bowling::Game "1..1" -- "1..1" bowling::Matchup : matchup3
bowling::Matchup "0..9999" --* "1..1" bowling::Tournament : matchups1
bowling::Player "0..1" -- "1..1" bowling::Game : player4
bowling::League "1..1" *-- "0..9999" bowling::Player : players0
bowling::Tournament "0..9999" -- "1..1" bowling::Alley : tournaments8
@enduml