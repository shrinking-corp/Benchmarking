@startuml
enum BookCategory {
  Biography
  GeneralFiction
  NonFiction
  SciFi
}
class lib::Book {
  + category : str
  + pages : int
  + title : str
}
class lib::LibSys {
}
class lib::Library {
  + location : str
  + name : str
}
class lib::Writer {
  + name : str
}
lib::Book "1..1" -- "1..1" lib::Writer : author3
