@startuml
class myfsm::Machine {
  + name : str
}
class myfsm::State {
  + name : str
}
class myfsm::Trans {
  + event : str
}
myfsm::Machine "1..1" -- "0..1" myfsm::State : initial1
myfsm::State "0..9999" --* "1..1" myfsm::Machine : states0
myfsm::State "1..1" -- "1..1" myfsm::Trans : target6
myfsm::Trans "0..9999" --* "1..1" myfsm::State : transitions4
@enduml