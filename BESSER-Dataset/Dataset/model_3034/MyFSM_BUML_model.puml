@startuml
class myfsm::Machine {
  + name : str
}
class myfsm::State {
  + name : str
}
class myfsm::Trans {
  + event : str
}
myfsm::Machine "1..1" -- "0..1" myfsm::State : initial1
myfsm::Machine "1..1" *-- "0..9999" myfsm::State : states0
myfsm::State "1..1" -- "1..1" myfsm::Trans : target6
myfsm::State "1..1" *-- "0..9999" myfsm::Trans : transitions4
@enduml