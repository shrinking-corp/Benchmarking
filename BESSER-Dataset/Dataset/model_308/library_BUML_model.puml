@startuml
enum BookCategory {
  Biography
  Mystery
  ScienceFiction
}
class library::Book {
  + category : str
  + pages : str
  + test : str
  + title : str
}
class library::Library {
  + name : str
}
class library::Writer {
  + name : str
}
library::Writer "1..1" -- "1..1" library::Book : author0
library::Book "0..9999" --* "1..1" library::Library : books2
library::Writer "1..1" -- "0..9999" library::Book : books4
library::Library "1..1" *-- "0..9999" library::Writer : writers1
@enduml