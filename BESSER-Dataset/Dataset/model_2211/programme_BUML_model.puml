@startuml
class StudyProgramme::Course {
  + code : str
  + credits : float
  + level : str
  + name : str
}
class StudyProgramme::CourseGroup {
  + status : str
}
class StudyProgramme::Department {
  + code : str
  + name : str
}
class StudyProgramme::Programme {
  + code : str
  + duration : int
  + name : str
}
class StudyProgramme::Semester {
  + creditConstraint : str
  + number : int
  + season : str
  + totalCredits : float
}
class StudyProgramme::Specialization {
  + name : str
}
