@startuml
class mm2::Book {
  + name : str
}
class mm2::Library {
  + name : str
}
class mm2::Loan {
  + name : str
}
class mm2::Member {
  + name : str
}
mm2::Book "1..1" -- "1..1" mm2::Loan : book5
mm2::Book "0..9999" --* "1..1" mm2::Library : books1
mm2::Library "1..1" *-- "0..9999" mm2::Loan : loans3
mm2::Member "1..1" -- "0..9999" mm2::Loan : loans8
mm2::Loan "0..9999" -- "1..1" mm2::Book : loans9
mm2::Member "1..1" -- "1..1" mm2::Loan : member6
mm2::Member "0..9999" --* "1..1" mm2::Library : members0
@enduml