@startuml
enum BookCategory {
  Biography
  Mystery
  ScienceFiction
}
class eavlibrary::Book {
  + category : str
  + pages : str
  + test : str
  + title : str
}
class eavlibrary::City {
  + name : str
}
class eavlibrary::Library {
  + name : str
}
class eavlibrary::Pen {
  + name : str
}
class eavlibrary::Writer {
  + abstract : str
  + image : str
  + name : str
}
eavlibrary::Book "1..1" -- "1..1" eavlibrary::Writer : author0
eavlibrary::Book "0..9999" --* "1..1" eavlibrary::Library : books2
eavlibrary::Book "0..9999" -- "1..1" eavlibrary::Writer : books4
eavlibrary::City "1..1" -- "1..1" eavlibrary::Writer : city5
eavlibrary::Pen "0..9999" --* "1..1" eavlibrary::Writer : pens7
eavlibrary::Writer "0..9999" --* "1..1" eavlibrary::Library : writers1
@enduml