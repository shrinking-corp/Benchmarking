@startuml
enum BookCategory {
  Art
  Drama
  History
  SciFi
}
class library::Book {
  + category : str
  + pages : int
  + title : str
}
class library::Library {
  + address : str
  + internalRequestCount : int
  + requestCount : int
  + sumOfPages : int
}
class library::Writer {
  + name : str
}
library::Book "1..1" -- "0..9999" library::Writer : authors6
library::Book "0..9999" --* "1..1" library::Library : books1
library::Book "0..9999" -- "1..1" library::Writer : books7
library::Book "0..1" -- "1..1" library::Writer : firstBook8
library::Book "0..9999" -- "1..1" library::Writer : scifiBooks11
library::Book "0..9999" -- "1..1" library::Library : someBooks3
library::Library "1..1" *-- "0..9999" library::Writer : writers0
@enduml