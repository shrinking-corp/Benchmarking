@startuml
enum EventType {
  Basic
  Conditioning
  External
  Intermediate
  Undevelopped
}
enum GateType {
  AND
  INHIBIT
  INTERMEDIATE
  OR
  ORLESS
  ORMORE
  PRIORITY_AND
  PRIORITY_OR
  XOR
}
class emfta::Event {
  + description : str
  + name : str
  + probability : float
  + referenceCount : int
  + relatedObject : str
  + type : str
}
class emfta::FTAModel {
  + comments : str
  + description : str
  + name : str
}
class emfta::Gate {
  + description : str
  + nbOccurrences : int
  + type : str
}
emfta::Event "0..9999" -- "1..1" emfta::Gate : events1
emfta::Event "0..9999" --* "1..1" emfta::FTAModel : events6
emfta::Event "1..1" *-- "0..1" emfta::Gate : gate0
emfta::Event "0..1" -- "1..1" emfta::FTAModel : root4
@enduml