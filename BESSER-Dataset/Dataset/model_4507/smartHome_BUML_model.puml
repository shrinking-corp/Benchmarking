@startuml
enum DurationUnit {
  MINUTE
  SECOND
}
enum Operator {
  EQUALS
  INFERIOR
  SUPERIOR
}
class smartHome::Condition {
  + operand : int
  + operator : str
}
class smartHome::Duration {
  + unit : str
  + value : int
}
class smartHome::Event {
  + description : str
}
class smartHome::Location {
  + name : str
}
class smartHome::Rule {
}
class smartHome::Sensor {
  + dataFile : str
  + name : str
  + value : int
}
class smartHome::SensorType {
  + name : str
}
class smartHome::SensorValue {
}
class smartHome::SmartHome {
}
smartHome::Condition "1..9999" --* "1..1" smartHome::Rule : conditions10
smartHome::Duration "1..1" --* "1..1" smartHome::Rule : duration14
smartHome::Event "1..1" --* "1..1" smartHome::Rule : event12
smartHome::Location "1..9999" --* "1..1" smartHome::SmartHome : locations3
smartHome::Rule "1..9999" --* "1..1" smartHome::SmartHome : rules8
smartHome::Condition "1..1" -- "1..1" smartHome::Sensor : sensor16
smartHome::Sensor "1..1" -- "1..1" smartHome::SensorType : sensorType0
smartHome::SensorType "1..9999" --* "1..1" smartHome::SmartHome : sensorTypes5
