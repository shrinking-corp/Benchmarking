@startuml
enum BookCategory {
  Biography
  Mystery
  ScienceFiction
}
class library::Book {
  + category : str
  + pages : str
  + title : str
}
class library::Library {
  + name : str
}
class library::Writer {
  + name : str
}
library::Writer "1..1" -- "1..1" library::Book : author0
library::Book "0..9999" --* "1..1" library::Library : books2
library::Book "0..9999" -- "1..1" library::Writer : books4
library::Writer "0..9999" --* "1..1" library::Library : writers1
@enduml